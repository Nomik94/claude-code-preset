"""
{Resource} 통합 테스트 — API 엔드포인트 테스트
"""

import pytest
from httpx import AsyncClient

pytestmark = pytest.mark.asyncio(loop_scope="session")


# === 생성 (Create) ===


async def test_create_{resource}_성공(client: AsyncClient) -> None:
    """유효한 데이터로 {Resource}를 생성하면 201을 반환한다."""
    # Given
    payload = {
        "name": "테스트 {Resource}",
        # TODO: 리소스에 맞는 필드 추가
    }

    # When
    response = await client.post("/{resource_kebab}", json=payload)

    # Then
    assert response.status_code == 201
    data = response.json()
    assert data["name"] == "테스트 {Resource}"
    assert "id" in data
    assert "createdAt" in data


async def test_create_{resource}_잘못된_데이터(client: AsyncClient) -> None:
    """빈 이름으로 생성하면 422를 반환한다."""
    # Given
    payload = {"name": ""}

    # When
    response = await client.post("/{resource_kebab}", json=payload)

    # Then
    assert response.status_code == 422


# === 목록 조회 (Read List) ===


async def test_get_{resource}_list_빈_목록(client: AsyncClient) -> None:
    """데이터가 없으면 빈 목록을 반환한다."""
    # When
    response = await client.get("/{resource_kebab}")

    # Then
    assert response.status_code == 200
    data = response.json()
    assert data["items"] == []
    assert data["total"] == 0


async def test_get_{resource}_list_페이지네이션(client: AsyncClient) -> None:
    """페이지네이션 파라미터가 정상 동작한다."""
    # When
    response = await client.get("/{resource_kebab}?page=1&size=10")

    # Then
    assert response.status_code == 200
    data = response.json()
    assert data["page"] == 1
    assert data["size"] == 10


# === 상세 조회 (Read One) ===


async def test_get_{resource}_존재하는_ID(client: AsyncClient) -> None:
    """존재하는 ID로 조회하면 200을 반환한다."""
    # Given: {Resource} 먼저 생성
    create_response = await client.post(
        "/{resource_kebab}",
        json={"name": "조회 테스트"},
    )
    {resource}_id = create_response.json()["id"]

    # When
    response = await client.get(f"/{resource_kebab}/{{{resource}_id}}")

    # Then
    assert response.status_code == 200
    assert response.json()["id"] == {resource}_id


async def test_get_{resource}_없는_ID(client: AsyncClient) -> None:
    """존재하지 않는 ID로 조회하면 404를 반환한다."""
    # When
    response = await client.get("/{resource_kebab}/99999")

    # Then
    assert response.status_code == 404


# === 수정 (Update) ===


async def test_update_{resource}_성공(client: AsyncClient) -> None:
    """유효한 데이터로 수정하면 200을 반환한다."""
    # Given: {Resource} 먼저 생성
    create_response = await client.post(
        "/{resource_kebab}",
        json={"name": "수정 전"},
    )
    {resource}_id = create_response.json()["id"]

    # When
    response = await client.patch(
        f"/{resource_kebab}/{{{resource}_id}}",
        json={"name": "수정 후"},
    )

    # Then
    assert response.status_code == 200
    assert response.json()["name"] == "수정 후"


# === 삭제 (Delete) ===


async def test_delete_{resource}_성공(client: AsyncClient) -> None:
    """존재하는 ID로 삭제하면 204를 반환한다."""
    # Given: {Resource} 먼저 생성
    create_response = await client.post(
        "/{resource_kebab}",
        json={"name": "삭제 테스트"},
    )
    {resource}_id = create_response.json()["id"]

    # When
    response = await client.delete(f"/{resource_kebab}/{{{resource}_id}}")

    # Then
    assert response.status_code == 204


async def test_delete_{resource}_없는_ID(client: AsyncClient) -> None:
    """존재하지 않는 ID로 삭제하면 404를 반환한다."""
    # When
    response = await client.delete("/{resource_kebab}/99999")

    # Then
    assert response.status_code == 404
